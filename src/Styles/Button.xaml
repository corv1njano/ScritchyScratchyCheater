<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:ScritchyScratchyCheater.Controls">

    <Style TargetType="Button" x:Key="Button.Base">
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource Font.Secondary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontFamily" Value="{StaticResource Montserrat.Medium}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style TargetType="Button" x:Key="Button.Dialog" BasedOn="{StaticResource Button.Base}">
        <Setter Property="Background" Value="{StaticResource ControlElement.Flat.BackgroundDark}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" TargetName="ButtonBorder" Value="{StaticResource Titlebar.Background.Button.Hover}"/>
                            <Setter Property="Foreground" Value="{StaticResource Font.Secondary.Hover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:BetterButton}" x:Key="Button.Modern" BasedOn="{StaticResource Button.Base}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:BetterButton}">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <Border.Resources>
                            <controls:BindingProxy x:Key="proxy" Data="{Binding Icon, RelativeSource={RelativeSource AncestorType=controls:BetterButton}}"/>
                        </Border.Resources>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,4">
                            <Rectangle x:Name="Rect"
                                       Height="{TemplateBinding IconHeight}"
                                       Width="{TemplateBinding IconWidth}"
                                       VerticalAlignment="Center"
                                       Fill="{TemplateBinding ForegroundColor}">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="{Binding Data, Source={StaticResource proxy}}"/>
                                </Rectangle.OpacityMask>
                            </Rectangle>
                            <TextBlock x:Name="Text"
                                       FontSize="{TemplateBinding BetterButtonFontSize}"
                                       Style="{StaticResource TextBlock.Base}"
                                       Foreground="{TemplateBinding ForegroundColor}"
                                       HorizontalAlignment="{TemplateBinding TextHorizontalAlignment}"
                                       Margin="5,0,0,0"
                                       Text="{TemplateBinding Text}"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" TargetName="Text" Value="{TemplateBinding ForegroundHoverColor}"/>
                            <Setter Property="Fill" TargetName="Rect" Value="{TemplateBinding ForegroundHoverColor}"/>
                            <Setter Property="BorderBrush" Value="{TemplateBinding BorderHoverColor}"/>
                            <Setter Property="Background" Value="{TemplateBinding BackgroundHoverColor}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{TemplateBinding DisabledForegroundColor}"/>
                            <Setter Property="Background" Value="{TemplateBinding DisabledBackgroundColor}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" x:Key="Button.WindowControl.Minimize" BasedOn="{StaticResource Button.Base}">
        <Setter Property="Cursor" Value="Arrow"/>
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        <Setter Property="Background" Value="{DynamicResource Titlebar.Background}"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Width" Value="40"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                        Background="{TemplateBinding Background}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        BorderBrush="{TemplateBinding BorderBrush}">
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Rectangle x:Name="Rect" Fill="{StaticResource Font.Secondary}" Height="10" Width="10">
                                <Rectangle.OpacityMask>
                                    <ImageBrush ImageSource="{StaticResource WindowControl.Minimize}" Stretch="Uniform"/>
                                </Rectangle.OpacityMask>
                            </Rectangle>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Rect" Property="Fill" Value="#e8e8e8"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                        To="{StaticResource Color.Titlebar.Button.Hover}"
                                        Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                        To="{StaticResource Color.Titlebar.Background}"
                                        Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

