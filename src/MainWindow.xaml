<Window x:Class="ScritchyScratchyCheater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScritchyScratchyCheater"
        xmlns:controls="clr-namespace:ScritchyScratchyCheater.Controls"
        mc:Ignorable="d"
        Title="Scritchy Scratchy Cheater"
        Height="650" Width="670"
        MinHeight="650" MinWidth="670"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="{StaticResource CJG.Window}"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        DragLeave="Window_DragLeave"
        DragOver="Window_DragOver"
        Drop="Window_Drop">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding CurrentPage.DataContext.SaveChangesCommand}"/>
        <KeyBinding Key="F5" Command="{Binding CurrentPage.DataContext.ReloadSaveFileCommand}"/>
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CurrentPage.DataContext.CloseSaveFileCommand}"/>
        <KeyBinding Key="B" Modifiers="Ctrl" Command="{Binding CurrentPage.DataContext.CreateBackupCommand}"/>
        <KeyBinding Key="L" Modifiers="Ctrl" Command="{Binding CurrentPage.DataContext.OpenFileExplorerCommand}"/>
    </Window.InputBindings>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      UseAeroCaptionButtons="False"
                      ResizeBorderThickness="8"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- titlebar -->
        <Border Grid.Row="0"
                Background="{StaticResource CJG.TitleBar}"
                BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource CJG.Block.Border}">
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Image Source="/Resources/Images/AppLogo.png"
                           Width="20"
                           Height="20"
                           Margin="10,0"
                           VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Scritchy Scratchy Cheater"
                               Style="{StaticResource TextBlock.Base}"
                               Foreground="{StaticResource CJG.Font.TitleBar}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <StackPanel.Resources>
                        <Style TargetType="Rectangle">
                            <Setter Property="Height" Value="10"/>
                            <Setter Property="Width" Value="10"/>
                            <Setter Property="Fill" Value="{DynamicResource CJG.Font.TitleBar}"/>
                        </Style>
                    </StackPanel.Resources>
                    
                    <!-- update button (only visible when update check successfull) -->
                    <Button Style="{StaticResource Button.Titlebar.Update}"
                            Content="Update"
                            Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}"
                            Command="{Binding UpdateAppCommand}"
                            ToolTip="Download the latest update now"/>

                    <!-- info and support button -->
                    <Button Style="{StaticResource Button.TitleBar}" ToolTip="Support me!" Command="{Binding OpenSupportMeCommand}" Cursor="Hand">
                        <Rectangle Width="18" Height="18" Fill="{StaticResource CJG.Glyph.Heart}">
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="{StaticResource Icon.Heart}"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                    </Button>
                    <Button Style="{StaticResource Button.TitleBar}" ToolTip="About this App" Command="{Binding OpenAboutAppCommand}" Cursor="Hand">
                        <Rectangle Width="18" Height="18">
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="{StaticResource Icon.Info}"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                    </Button>
                    
                    <!-- window controls -->
                    <Button Style="{StaticResource Button.TitleBar}" Click="Button_Minimize">
                        <Rectangle>
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="{StaticResource WindowControl.Minimize}" Stretch="Uniform"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                    </Button>
                    <Button Style="{StaticResource Button.TitleBar}" Click="Button_Maximize">
                        <Rectangle>
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="{StaticResource WindowControl.Maximize}" Stretch="Uniform"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                    </Button>
                    <Button Style="{StaticResource Button.TitleBar.Close}" Click="Button_Close">
                        <Rectangle>
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="{StaticResource WindowControl.Close}" Stretch="Uniform"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <ContentControl Content="{Binding CurrentPage}" IsTabStop="False"/>
        </Grid>

        <!-- statusbar -->
        <Border Grid.Row="2"
                Background="{StaticResource CJG.StatusBar}"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource CJG.Block.Border}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Style="{StaticResource TextBlock.StatusBar}"
                           Text="{x:Static local:App.APP_VERSION}"/>
                <TextBlock Text="{Binding SelectedSaveFilePath}"
                           ToolTip="{Binding SaveFileTooltip}"
                           Grid.Column="1"
                           Style="{StaticResource TextBlock.StatusBar}"
                           HorizontalAlignment="Right"/>
            </Grid>
        </Border>

        <!-- drag valid overlay -->
        <Border Grid.RowSpan="3"
                Panel.ZIndex="999"
                Opacity="0"
                IsHitTestVisible="{Binding IsDragging}"
                Background="#80000000">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDragging}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Style="{StaticResource Border.DropFile}">
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <Rectangle Height="50" Width="50" Fill="{StaticResource CJG.Accent}" Margin="0,-10,0,20">
                        <Rectangle.OpacityMask>
                            <ImageBrush ImageSource="{StaticResource Icon.File}"/>
                        </Rectangle.OpacityMask>
                    </Rectangle>
                    <TextBlock Style="{StaticResource TextBlock.Base}"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               Text="Drop Save File here..."/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
