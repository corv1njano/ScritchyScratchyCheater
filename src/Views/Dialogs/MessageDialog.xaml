<Window x:Class="ScritchyScratchyCheater.Views.Dialogs.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScritchyScratchyCheater.Views.Dialogs"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterOwner"
        Title="Message" Height="200" Width="320"
        Background="{StaticResource CJG.Window}">

    <WindowChrome.WindowChrome>
        <WindowChrome ResizeBorderThickness="0"
                      CaptionHeight="40"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Vertical" Grid.Row="0" VerticalAlignment="Center" Margin="10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <StackPanel.Resources>
                    <Style TargetType="Rectangle">
                        <Setter Property="Height" Value="30"/>
                        <Setter Property="Width" Value="30"/>
                        <Setter Property="Margin" Value="0,0,8,0"/>
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </StackPanel.Resources>
                
                <Rectangle x:Name="NoticeInfo" Fill="{StaticResource CJG.Accent}">
                    <Rectangle.OpacityMask>
                        <ImageBrush ImageSource="{StaticResource Icon.Info}"/>
                    </Rectangle.OpacityMask>
                </Rectangle>
                <Rectangle x:Name="NoticeWarning" Fill="{StaticResource CJG.DialogType.Warning}">
                    <Rectangle.OpacityMask>
                        <ImageBrush ImageSource="{StaticResource Icon.Warning}"/>
                    </Rectangle.OpacityMask>
                </Rectangle>
                <Rectangle x:Name="NoticeError" Fill="{StaticResource CJG.DialogType.Error}">
                    <Rectangle.OpacityMask>
                        <ImageBrush ImageSource="{StaticResource Icon.Close}"/>
                    </Rectangle.OpacityMask>
                </Rectangle>

                <TextBlock x:Name="MessageTitle" Text="Title" Style="{StaticResource TextBlock.Base}" FontFamily="{StaticResource Montserrat}" FontWeight="Bold" Foreground="{StaticResource CJG.Font.TitleBar}" FontSize="16"/>
            </StackPanel>
            <TextBlock x:Name="MessageBody" Text="Message could not be displayed." Style="{StaticResource TextBlock.Base}" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="{StaticResource CJG.Block.Border}" Background="{StaticResource CJG.Block.Background}">
            <Grid>
                <Grid.Resources>
                    <Style TargetType="StackPanel">
                        <Setter Property="HorizontalAlignment" Value="Right"/>
                    </Style>
                </Grid.Resources>
                <StackPanel Margin="8" x:Name="ButtonOk" Visibility="Collapsed">
                    <Button Style="{StaticResource Button.Dialog.Preffered}" Content="OK" Click="ButtonYes_Click"/>
                </StackPanel>
                <StackPanel Margin="8" Orientation="Horizontal" x:Name="ButtonYesNo" Visibility="Collapsed">
                    <Button Style="{StaticResource Button.Dialog.Preffered}" Content="Yes" Margin="0,0,8,0" Click="ButtonYes_Click"/>
                    <Button Style="{StaticResource Button.Dialog}" Content="No" Click="ButtonNo_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Button Style="{StaticResource Button.Window.Close}" Click="Button_Close" Margin="10"/>
    </Grid>
</Window>
