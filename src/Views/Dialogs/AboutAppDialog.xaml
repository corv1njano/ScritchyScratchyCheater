                                <Run Style="{StaticResource Document.Run}" Text="edit Prestige Currency"/>
                            </Paragraph>

                            <Paragraph Style="{StaticResource Document.ListParagraph}">
                                <Run Style="{StaticResource Document.Run}" Text="- "/>
                                <Run Style="{StaticResource Document.Run}" Text="edit Tokens"/>
