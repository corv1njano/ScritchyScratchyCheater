<Window x:Class="ScritchyScratchyCheater.Views.Dialogs.AboutAppDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScritchyScratchyCheater.Views.Dialogs"
        xmlns:controls="clr-namespace:ScritchyScratchyCheater.Controls"
        mc:Ignorable="d"
        Title="About this App"
        Height="320" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource CJG.Window}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                  UseAeroCaptionButtons="False"
                  ResizeBorderThickness="8"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource CJG.TitleBar}"
                BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource CJG.Block.Border}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                               Text="About this App"
                               Style="{StaticResource TextBlock.Base}"
                               Foreground="{StaticResource CJG.Font.TitleBar}"
                               Margin="10,0"/>
                <Button Grid.Column="1" HorizontalAlignment="Right" Style="{StaticResource Button.TitleBar.Close}" Click="Button_Close">
                    <Rectangle Height="10" Width="10" Fill="{StaticResource CJG.Font.TitleBar}">
                        <Rectangle.OpacityMask>
                            <ImageBrush ImageSource="{StaticResource WindowControl.Close}" Stretch="Uniform"/>
                        </Rectangle.OpacityMask>
                    </Rectangle>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="10" VerticalAlignment="Center">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <TextBlock Text="{Binding AppNameAndVersion}" Style="{StaticResource TextBlock.Base}" FontSize="18" FontFamily="{StaticResource Montserrat}" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Style="{StaticResource TextBlock.AboutDialog}" Margin="0,32,0,0" Text="Copyright © 2026 corv1njano"/>
                <TextBlock Style="{StaticResource TextBlock.AboutDialog}" Margin="0,16,0,0" Text="This program is licensed under the GPL-3.0 license."/><!--  See the official GitHub page for more licensing details.-->
                <TextBlock Style="{StaticResource TextBlock.AboutDialog}" Margin="0,16,0,0" Text="This tool my contain errors. Always back up your save files to prevent data loss or file corruption."/>

                <Grid Margin="00,40,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <controls:ButtonWithIcon Grid.Column="0" Style="{StaticResource Button.WithIcon}" Height="30" Text="GitHub" Icon="{StaticResource Icon.GitHub}" IconHeight="17" IconWidth="17"
                                             Command="{Binding OpenGitHubCommand}"/>
                    <controls:ButtonWithIcon Grid.Column="2" Style="{StaticResource Button.WithIcon}" Height="30" Text="License" Icon="{StaticResource Icon.License}"
                                             Command="{Binding OpenLicenseCommand}"/>
                    <controls:ButtonWithIcon Grid.Column="4" Style="{StaticResource Button.WithIcon}" Height="30" Text="Sponsor" Icon="{StaticResource Icon.Heart}"
                                             Command="{Binding OpenSponsorCommand}"/>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
