<Window x:Class="ScritchyScratchyCheater.Views.Dialogs.CreateBackupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScritchyScratchyCheater.Views.Dialogs"
        xmlns:controls="clr-namespace:ScritchyScratchyCheater.Controls"
        mc:Ignorable="d"
        Title="Create Backup"
        SizeToContent="Height" Width="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource CJG.Window}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Create backup"
                   Style="{StaticResource TextBlock.Base}"
                   Foreground="{StaticResource CJG.Font.TitleBar}"/>
        <TextBlock Grid.Row="1"
                   Text="Do you want to create a backup of your save file before editing?"
                   FontSize="14"
                   Margin="0,15"
                   Style="{StaticResource TextBlock.Base}"
                   Foreground="{StaticResource CJG.Font.Normal}"/>

        <Grid Grid.Row="2">
            <Border Grid.Row="0" Style="{StaticResource Border.Default}">
                <Grid Margin="0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource TextBlock.Base}" Margin="8,0" Text="Destination:"/>
                    <controls:ValidatedTextBox Grid.Column="1"
                                               Style="{StaticResource TextBox.Validated}"
                                               Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}"
                                               IsValid="{Binding IsTargetPathValid}"/>
                    <controls:ButtonWithIcon Style="{StaticResource Button.WithIcon}"
                                             Margin="8,0"
                                             Grid.Column="2"
                                             Text="Browse"
                                             ToolTip="Browse for Destination Folder"
                                             Icon="{StaticResource Icon.Folder}"
                                             IconHeight="18" IconWidth="18"
                                             Command="{Binding OpenTargetSelectionCommand}"/>
                </Grid>
            </Border>
        </Grid>

        <Border Style="{StaticResource Border.Default}" Grid.Row="3" Margin="0,10,0,0">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource TextBlock.Base.Bold}" Text="Export Settings"/>
                <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,8,0,0">
                    <CheckBox Style="{StaticResource CheckBox.Default}" IsChecked="{Binding IncludeTimetamp, Mode=TwoWay}" Content="Include Timestamp in File Name"/>
                    <CheckBox Style="{StaticResource CheckBox.Default}" IsChecked="{Binding OpenFolder, Mode=TwoWay}" Content="Open Destination Folder after Export"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Orientation="Horizontal" Grid.Row="4" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Grid>
                <Button Style="{StaticResource Button.Dialog.Preffered}" Content="Export" Command="{Binding CreateBackupCommand}" IsEnabled="{Binding CanExport}"/>
                <Rectangle Fill="Transparent" Cursor="No"
                           Visibility="{Binding CanExport, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>
            </Grid>
            <Button Style="{StaticResource Button.Dialog}" Content="Cancel" Margin="8,0,0,0" Click="Button_Close"/>
        </StackPanel>
        
        <Button Grid.Column="1"
                Style="{StaticResource Button.Window.Close}"
                Click="Button_Close"/>
    </Grid>
</Window>
