<UserControl x:Class="ScritchyScratchyCheater.Views.Pages.StartingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ScritchyScratchyCheater.Views.Pages"
             xmlns:controls="clr-namespace:ScritchyScratchyCheater.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="620"
             Background="{StaticResource CJG.Window.Background}">

    <UserControl.Resources>
        <Style TargetType="Rectangle" x:Key="rect">
            <Setter Property="Height" Value="25"/>
            <Setter Property="Width" Value="25"/>
            <Setter Property="Fill" Value="{StaticResource CJG.Accent}"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10,-20,10,10" Width="600">
        <Grid VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Vertical">
                <StackPanel.Resources>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource TextBlock.Base}">
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                    </Style>
                </StackPanel.Resources>
                <TextBlock Text="Welcome to" Margin="0,0,0,3"/>
                <TextBlock Text="Scritchy Scratchy Cheater" FontSize="24" FontWeight="Bold" FontFamily="{StaticResource Montserrat}"/>
                <TextBlock Text="The compact save file editor for the game Scritchy Scratchy." Margin="0,15,0,0"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,35,0,0"
                    BorderThickness="1"
                    BorderBrush="{StaticResource CJG.Block.Border}"
                    Background="{StaticResource CJG.Block.Background}"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Style="{StaticResource TextBlock.Base}"
                               Text="GET STARTED"
                               FontFamily="{StaticResource Montserrat}"
                               FontWeight="Bold"
                               Foreground="{StaticResource CJG.Accent}"
                               FontSize="16"
                               Padding="10"/>
                    <Grid Grid.Row="1" Margin="20,12,20,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Style="{StaticResource rect}">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="{StaticResource Icon.File}"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <TextBlock Grid.Row="0" Style="{StaticResource TextBlock.Base}" Margin="10,0,0,0" Text="Load Save File"/>
                            </StackPanel>
                            <TextBlock Grid.Row="0" Style="{StaticResource TextBlock.Base}"
                                       Margin="0,10"
                                       FontSize="12"
                                       Opacity="0.6"
                                       TextWrapping="Wrap"
                                       Text="Automatically load the save from the default location."/>
                            <Button Style="{StaticResource Button.StartingPage.Select}"
                                    Content="Load Save File"
                                    Command="{Binding LoadDefaultSaveFileCommand}"/>
                        </StackPanel>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Width="1" Margin="0,0,0,4" HorizontalAlignment="Center" Background="{StaticResource CJG.Block.Border}"/>
                            <Border Grid.Row="1"
                                    Width="42"
                                    Height="42"
                                    CornerRadius="21"
                                    Background="{StaticResource CJG.Window.Background}"
                                    BorderBrush="{StaticResource CJG.Block.Border}"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource TextBlock.Base}"
                                           Text="OR"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Row="2" Width="1" Margin="0,4,0,0" HorizontalAlignment="Center" Background="{StaticResource CJG.Block.Border}"/>
                        </Grid>

                        <StackPanel Grid.Column="2" Orientation="Vertical">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Style="{StaticResource rect}">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="{StaticResource Icon.Folder}"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <TextBlock Grid.Row="0" Style="{StaticResource TextBlock.Base}"
                                           Margin="10,0,0,0"
                                           Text="Browse for File"/>
                            </StackPanel>
                            <TextBlock Grid.Row="0" Style="{StaticResource TextBlock.Base}"
                                       Margin="0,10"
                                       Opacity="0.6"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Text="Manually browse and select a save file in JSON format."/>
                            <Button Style="{StaticResource Button.StartingPage.Select}"
                                    Content="Browse for File"
                                    Command="{Binding BrowseSaveFileCommand}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,10,0,0"
                    BorderThickness="1"
                    BorderBrush="{StaticResource CJG.Block.Border}"
                    Background="{StaticResource CJG.Block.Background}"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Style="{StaticResource TextBlock.Base}"
                               Text="QUICK LINKS"
                               FontFamily="{StaticResource Montserrat}"
                               FontWeight="Bold"
                               Foreground="{StaticResource CJG.Accent}"
                               FontSize="16"
                               Padding="10"/>
                    <Grid Grid.Row="1" Margin="20,12,20,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.Resources>
                            <Style TargetType="TextBlock" x:Key="txtDesc" BasedOn="{StaticResource TextBlock.Base}">
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Opacity" Value="0.6"/>
                                <Setter Property="TextWrapping" Value="Wrap"/>
                                <Setter Property="Margin" Value="0,5,0,0"/>
                            </Style>
                        </Grid.Resources>

                        <Button Style="{StaticResource Button.StartingPage.Link}" Grid.Column="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Style="{StaticResource rect}" Height="22" Width="22" Margin="3,0">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="{StaticResource Icon.GitHub}"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="8,0,5,0">
                                    <TextBlock Style="{StaticResource TextBlock.Base}" Text="GitHub"/>
                                    <TextBlock Style="{StaticResource txtDesc}" Text="View source code on GitHub."/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button Style="{StaticResource Button.StartingPage.Link}" Grid.Column="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Style="{StaticResource rect}">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="{StaticResource Icon.Heart}"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="8,0,5,0">
                                    <TextBlock Style="{StaticResource TextBlock.Base}" Text="Sponsor"/>
                                    <TextBlock Style="{StaticResource txtDesc}" Text="Support me and the project."/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button Style="{StaticResource Button.StartingPage.Link}" Grid.Column="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.Column="0" Style="{StaticResource rect}">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="{StaticResource Icon.Files}"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="8,0,5,0">
                                    <TextBlock Style="{StaticResource TextBlock.Base}" Text="Saves"/>
                                    <TextBlock Style="{StaticResource txtDesc}" Text="Discover example save files."/>
                                </StackPanel>
                            </Grid>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Style="{StaticResource TextBlock.Base}"
                   Grid.Row="3"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom">
            <Run Text="Made with"/>
            <Run Text="♥️" Foreground="{StaticResource CJG.Accent}"/>
            <Run Text="by corv1njano"/>
        </TextBlock>
    </Grid>
</UserControl>
