<UserControl x:Class="ScritchyScratchyCheater.Views.Pages.EditorV01Page"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ScritchyScratchyCheater.Views.Pages"
             xmlns:controls="clr-namespace:ScritchyScratchyCheater.Controls"
             xmlns:converters="clr-namespace:ScritchyScratchyCheater.Utilities.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="620"
             Background="{StaticResource CJG.Window}"
             Loaded="Editor_Loaded">

    <UserControl.Resources>
        <Style TargetType="Image" x:Key="blockImg">
            <Setter Property="Height" Value="25"/>
            <Setter Property="Width" Value="25"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="blockTxt" BasedOn="{StaticResource TextBlock.Base}">
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>
        <Style TargetType="Border" x:Key="blockBod" BasedOn="{StaticResource Border.Default}">
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style TargetType="Button" x:Key="blockbtn" BasedOn="{StaticResource Button.Editor.Generic}">
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Content" Value="Max"/>
            <Setter Property="ToolTip" Value="Set max. Value for this Field"/>
        </Style>
        <Style TargetType="Grid" x:Key="contentGrid">
            <Setter Property="MaxWidth" Value="800"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderThickness="0,0,0,1"
                Background="{StaticResource CJG.ControlBar}"
                BorderBrush="{StaticResource CJG.Block.Border}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Grid Margin="8">
                        <controls:ButtonWithIcon Command="{Binding SaveChangesCommand}"
                                                 IsEnabled="{Binding CanSave}"
                                                 Style="{StaticResource Button.WithIcon}"
                                                 Text="Save"
                                                 Icon="{StaticResource Icon.Save}"
                                                 ToolTip="Save all Changes"/>
                        <Rectangle Fill="Transparent" Cursor="No"
                                   Visibility="{Binding CanSave, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>
                    </Grid>
                    <controls:ButtonWithIcon Command="{Binding ReloadSaveFileCommand}" 
                                             Style="{StaticResource Button.WithIcon}"
                                             Margin="0,8,8,8" 
                                             Text="Reload" 
                                             Icon="{StaticResource Icon.Refresh}" 
                                             ToolTip="Reload current Save File"/>
                    <controls:ButtonWithIcon Command="{Binding CloseSaveFileCommand}" 
                                             Style="{StaticResource Button.WithIcon}"
                                             Margin="0,8,0,8" 
                                             Text="Close" 
                                             Icon="{StaticResource Icon.Close}"
                                             IconHeight="22"
                                             IconWidth="22"
                                             ToolTip="Close current Save File"/>
                </StackPanel>
                <controls:ButtonWithIcon Command="{Binding OpenFileExplorerCommand}" 
                                         Style="{StaticResource Button.WithIcon}"
                                         Grid.Column="1" 
                                         HorizontalAlignment="Right" 
                                         Margin="0,8,8,8"
                                         Text="Locate Save" 
                                         Icon="{StaticResource Icon.Folder}" 
                                         IconHeight="18"
                                         IconWidth="18"
                                         ToolTip="Open current Save File in File Explorer"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Style="{StaticResource TabControl.Modern}" Margin="10,0,10,10">
            <controls:IconTabItem Header="Progress" Icon="{StaticResource Icon.Progress}">
                <Grid Style="{StaticResource contentGrid}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource Border.Default}">
                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Image Grid.Row="0" Grid.Column="0" Style="{StaticResource blockImg}" Source="{Binding MoneyIcon}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource blockTxt}" Text="Money:"/>
                            <controls:ValidatedTextBox Grid.Row="0" Grid.Column="2" Style="{StaticResource TextBox.Validated}" Margin="0,0,8,0" Text="{Binding MoneyText, UpdateSourceTrigger=PropertyChanged}" IsValid="{Binding IsMoneyValid}"/>
                            <Button Grid.Row="0" Grid.Column="3" Style="{StaticResource blockbtn}" Command="{Binding MaxMoneyCommand}"/>

                            <Border Grid.Row="1" Grid.ColumnSpan="4" Style="{StaticResource blockBod}"/>

                            <Image Grid.Row="2" Grid.Column="0" Style="{StaticResource blockImg}" Source="{Binding SoulsIcon}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource blockTxt}" Text="Souls:"/>
                            <controls:ValidatedTextBox Grid.Row="2" Grid.Column="2" Style="{StaticResource TextBox.Validated}" Margin="0,0,8,0" Text="{Binding SoulsText, UpdateSourceTrigger=PropertyChanged}" IsValid="{Binding IsSoulsValid}"/>
                            <Button Grid.Row="2" Grid.Column="3" Style="{StaticResource blockbtn}" Command="{Binding MaxSoulsCommand}"/>
                        </Grid>
                    </Border>
                </Grid>
            </controls:IconTabItem>

            <controls:IconTabItem Header="Upgrades" Icon="{StaticResource Icon.Upgrades}">
                <TextBlock Style="{StaticResource TextBlock.Base}" HorizontalAlignment="Center" Text="Upgrade editing will be available soon!"/>
            </controls:IconTabItem>

            <controls:IconTabItem Header="Prestige" Icon="{StaticResource Icon.Prestige}">
                <Grid Style="{StaticResource contentGrid}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Border.Default}">
                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Image Grid.Row="0" Grid.Column="0" Style="{StaticResource blockImg}" Source="{Binding PrestigeIcon}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource blockTxt}" Text="Prestige:"/>
                            <controls:ValidatedTextBox Grid.Row="0" Grid.Column="2" Style="{StaticResource TextBox.Validated}" Margin="0,0,8,0" Text="{Binding PrestigeText, UpdateSourceTrigger=PropertyChanged}" IsValid="{Binding IsPrestigeValid}"/>
                            <Button Grid.Row="0" Grid.Column="3" Style="{StaticResource blockbtn}" Command="{Binding MaxPrestigeCommand}"/>
                        </Grid>
                    </Border>
                </Grid>
            </controls:IconTabItem>

            <controls:IconTabItem Header="Achievements" Icon="{StaticResource Icon.Achievements}">
                <Grid Style="{StaticResource contentGrid}">
                    <Border Style="{StaticResource Border.Default}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    CornerRadius="4,4,0,0"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{StaticResource CJG.Block.Border}"
                                    Background="{StaticResource CJG.Block.Background}">
                                <Grid Margin="0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>

                                    <controls:TextBoxPlaceholder Grid.Column="0"
                                             Margin="8,0"
                                             Style="{StaticResource TextBox.ListSearch}"
                                             PlaceholderText="Search achievement..."
                                             IsClearable="True"
                                             Text="{Binding SearchAchievement, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Grid.Column="1" Content="Unlock All" Style="{StaticResource blockbtn}" Command="{Binding UnlockAllAchievementsCommand}" ToolTip="Unlock all Achievements"/>
                                    <Button Grid.Column="2" Content="Claim All" Style="{StaticResource blockbtn}" Command="{Binding ClaimAllAchievementsCommand}" ToolTip="Claim all Achievements"/>
                                </Grid>
                            </Border>

                            <ListBox Grid.Row="1"
                                     Style="{StaticResource ListBox.Default}"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.CanContentScroll="False"
                                     ItemsSource="{Binding AchievementsView}"
                                     Visibility="{Binding HasEntries, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Left" Orientation="Horizontal">
                                                <Image Height="30" Width="30" Source="{Binding Achievement.IconId, Converter={StaticResource IconIdToImageConverter}}"/>
                                                <TextBlock Text="{Binding Achievement.Name}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <CheckBox Style="{StaticResource CheckBox.Default}" IsChecked="{Binding IsUnlocked, Mode=TwoWay}" Margin="8,0,0,0"/>
                                                <TextBlock Text="Unlocked" VerticalAlignment="Center"/>
                                                <CheckBox Style="{StaticResource CheckBox.Default}" IsChecked="{Binding IsClaimed, Mode=TwoWay}" Margin="16,0,0,0"/>
                                                <TextBlock Text="Claimed" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <TextBlock Text="No achievements found with that name."
                                       HorizontalAlignment="Center" Style="{StaticResource TextBlock.Base}" Grid.Row="1"
                                       Visibility="{Binding HasEntries, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>
                        </Grid>
                    </Border>
                </Grid>
            </controls:IconTabItem>

            <controls:IconTabItem Header="Cosmetics" Icon="{StaticResource Icon.Cosmetics}">
                <Grid Style="{StaticResource contentGrid}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Border.Default}">
                        <Grid Margin="0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Image Grid.Row="0" Grid.Column="0" Style="{StaticResource blockImg}" Source="{Binding TokensIcon}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource blockTxt}" Text="Tokens:"/>
                            <controls:ValidatedTextBox Grid.Row="0" Grid.Column="2" Style="{StaticResource TextBox.Validated}" Margin="0,0,8,0" Text="{Binding TokensText, UpdateSourceTrigger=PropertyChanged}" IsValid="{Binding IsTokensValid}"/>
                            <Button Grid.Row="0" Grid.Column="3" Style="{StaticResource blockbtn}" Command="{Binding MaxTokensCommand}"/>
                        </Grid>
                    </Border>
                </Grid>
            </controls:IconTabItem>

            <controls:IconTabItem Header="Misc" Icon="{StaticResource Icon.Misc}">
                <TextBlock Style="{StaticResource TextBlock.Base}" HorizontalAlignment="Center" Text="Other editing options will be available soon!"/>
            </controls:IconTabItem>
        </TabControl>
    </Grid>
</UserControl>
