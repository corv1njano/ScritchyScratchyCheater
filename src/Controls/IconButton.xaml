<Button x:Class="ScritchyScratchyCheater.Controls.IconButton"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:ScritchyScratchyCheater.Controls"
        mc:Ignorable="d" 
        d:DesignHeight="450" d:DesignWidth="800">

    <Button.Resources>
        <Style TargetType="local:IconButton" BasedOn="{StaticResource Button.Base}">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{StaticResource ControlElement.Flat.Background}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="local:IconButton">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}}">
                            <Border.Resources>
                                <local:BindingProxy x:Key="proxy" Data="{Binding Icon, RelativeSource={RelativeSource AncestorType=local:IconButton}}"/>
                            </Border.Resources>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,4">
                                <Rectangle x:Name="Rect"
                                           Height="{Binding IconHeight, RelativeSource={RelativeSource TemplatedParent}}"
                                           Width="{Binding IconWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                           VerticalAlignment="Center"
                                           Fill="{StaticResource Font.Secondary}">
                                    <Rectangle.OpacityMask>
                                        <ImageBrush ImageSource="{Binding Data, Source={StaticResource proxy}}"/>
                                    </Rectangle.OpacityMask>
                                </Rectangle>
                                <TextBlock x:Name="Text"
                                           FontSize="{Binding IconButtonFontSize, RelativeSource={RelativeSource TemplatedParent}}"
                                           Style="{StaticResource TextBlock.Base}"
                                           Foreground="{StaticResource Font.Secondary}"
                                           Margin="5,0,0,0"
                                           Text="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" TargetName="Text" Value="{StaticResource Font.Secondary.Hover}"/>
                                <Setter Property="Fill" TargetName="Rect" Value="{StaticResource Font.Secondary.Hover}"/>
                            </Trigger>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Text" Property="Margin" Value="0"/>
                                <Setter TargetName="Rect" Property="HorizontalAlignment" Value="Center"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Button.Resources>
</Button>
