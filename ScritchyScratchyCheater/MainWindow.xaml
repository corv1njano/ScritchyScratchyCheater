<Window x:Class="ScritchyScratchyCheater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScritchyScratchyCheater"
        xmlns:controls="clr-namespace:ScritchyScratchyCheater.Controls"
        mc:Ignorable="d"
        Title="Scritchy Scratchy Cheater" Height="560" Width="580"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        Background="{StaticResource Window.Background}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      UseAeroCaptionButtons="False"
                      ResizeBorderThickness="8"/>
    </WindowChrome.WindowChrome>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- titlebar -->
        <Grid Grid.Row="0" Background="{StaticResource Titlebar.Background}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Image Source="/Resources/Images/app_logo.png"
                       Width="22"
                       Height="22"
                       Margin="10,0"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="Scritchy Scratchy Cheater"
                           Style="{StaticResource TextBlock.Base}"
                           Foreground="{StaticResource Font.Secondary}"
                           FontSize="14"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <StackPanel.Resources>
                    <Style TargetType="Rectangle">
                        <Setter Property="Height" Value="10"/>
                        <Setter Property="Width" Value="10"/>
                        <Setter Property="Fill" Value="{DynamicResource Font.Secondary}"/>
                    </Style>
                </StackPanel.Resources>
                <Button Style="{StaticResource Button.WindowControl.Info}" ToolTip="About this App" Command="{Binding OpenAboutAppCommand}"/>
                <Button Style="{StaticResource Button.WindowControl.Minimize}" Click="Button_Minimize"/>
                <Button Style="{StaticResource Button.WindowControl.Close}" Click="Button_Close"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <ContentControl Content="{Binding CurrentPage}" IsTabStop="False"/>
        </Grid>

        <!-- statusbar -->
        <Grid Grid.Row="2" Background="{StaticResource Titlebar.Background}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Style="{StaticResource TextBlock.StatusBar}" Text="v1.2.0"/>
            <TextBlock Text="{Binding SelectedSaveFilePath}" ToolTip="{Binding SaveFileTooltip}" Grid.Column="1" Style="{StaticResource TextBlock.StatusBar}" HorizontalAlignment="Right"/>
        </Grid>
    </Grid>
</Window>
