<Window x:Class="ScritchyScratchyCheater.Views.Dialogs.AboutAppDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScritchyScratchyCheater.Views.Dialogs"
        xmlns:controls="clr-namespace:ScritchyScratchyCheater.Controls"
        mc:Ignorable="d"
        Title="About this App" Height="430" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Window.Background}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                  UseAeroCaptionButtons="False"
                  ResizeBorderThickness="8"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- titlebar -->
        <Grid Grid.Row="0" Background="{StaticResource Titlebar.Background}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="About this App"
                           Style="{StaticResource TextBlock.Base}"
                           Foreground="{StaticResource Font.Secondary}"
                           FontSize="14"
                           Margin="10,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <StackPanel.Resources>
                    <Style TargetType="Rectangle">
                        <Setter Property="Height" Value="10"/>
                        <Setter Property="Width" Value="10"/>
                        <Setter Property="Fill" Value="{DynamicResource Font.Secondary}"/>
                    </Style>
                </StackPanel.Resources>
                <Button Style="{StaticResource Button.WindowControl.Close}" Click="Button_Close"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="8,0,8,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TabControl Grid.Row="0" Style="{StaticResource TabControl.Modern}">
                <controls:IconTabItem Header="About" Icon="{StaticResource Icon.Info}">
                    <Grid Margin="10,0">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <Image Source="/Resources/Images/AppLogo.png" Width="50"/>
                            <TextBlock Text="{Binding AppNameAndVersion}" Style="{StaticResource TextBlock.Base}" Margin="0,8,0,0" FontSize="18" FontFamily="{StaticResource Montserrat}" FontWeight="Bold" HorizontalAlignment="Center"/>

                            <TextBlock Style="{StaticResource TextBlock.AboutDialog}" Margin="0,37,0,0"
                                       Text="Copright © 2026 corv1njano - All rights reserved."/>
                            <TextBlock Style="{StaticResource TextBlock.AboutDialog}" Margin="0,20,0,0"
                                       Text="This program is licensed under the GPL-3.0 license. See the official GitHub page for more licensing details."/>
                            <TextBlock Style="{StaticResource TextBlock.AboutDialog}" Margin="0,20,0,0"
                                       Text="This tool my contain errors. Always back up your save files to prevent data loss or file corruption."/>
                           
                        </StackPanel>
                    </Grid>
                </controls:IconTabItem>
                <!--<controls:IconTabItem Header="License" Icon="{StaticResource Icon.License}">
                    MaxHeight to make it scroll, grid height of * does not work
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" MaxHeight="350">
                        <TextBlock Style="{StaticResource TextBlock.Base}"
                                       TextWrapping="Wrap"
                                       FontSize="11"
                                       TextAlignment="Justify"
                                       Text="{Binding LicenseText}">
                        </TextBlock>
                    </ScrollViewer>
                </controls:IconTabItem>-->
                <controls:IconTabItem Header="Patch Notes" Icon="{StaticResource Icon.License}"></controls:IconTabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
