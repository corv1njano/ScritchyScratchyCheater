<UserControl x:Class="ScritchyScratchyCheater.Views.Pages.EditorV01"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ScritchyScratchyCheater.Views.Pages"
             xmlns:controls="clr-namespace:ScritchyScratchyCheater.Controls"
             xmlns:converters="clr-namespace:ScritchyScratchyCheater.Utilities.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="550"
             Background="{StaticResource Window.Background}"
             Loaded="Editor_Loaded">

    <UserControl.Resources>
        <converters:IconIdToImageConverter x:Key="IconIdToImageConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{StaticResource ControlElement.Flat.Background}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <controls:IconButton Command="{Binding SaveChangesCommand}" Margin="8" Text="Save" Icon="{StaticResource Icon.Save}" ToolTip="Save all Changes"/>
                <controls:IconButton Command="{Binding ReloadSaveFileCommand}" Margin="0,8,8,8" Text="Reload" Icon="{StaticResource Icon.Refresh}" ToolTip="Reload current Save File"/>
                <controls:IconButton Command="{Binding CloseSaveFileCommand}" Margin="0,8,8,8" Text="Close" Icon="{StaticResource Icon.Close}" ToolTip="Close current Save File"/>
            </StackPanel>
            <controls:IconButton Command="{Binding OpenFileExplorerCommand}" Grid.Column="1" HorizontalAlignment="Right" Margin="0,8,8,8" Text="Locate" Icon="{StaticResource Icon.Folder}" ToolTip="Open in File Explorer"/>
        </Grid>

        <TabControl Grid.Row="1" Style="{StaticResource TabControl.Modern}" Margin="8,0,8,8">
            <controls:IconTabItem Header="Progress" Icon="{StaticResource Icon.Progress}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.Resources>
                        <Style TargetType="Image">
                            <Setter Property="Height" Value="25"/>
                            <Setter Property="Width" Value="25"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                        <Style TargetType="TextBlock" x:Key="def" BasedOn="{StaticResource TextBlock.Base}">
                            <Setter Property="Margin" Value="8,0,0,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </Grid.Resources>

                    <Image Grid.Column="0" Grid.Row="0" Source="{Binding MoneyIcon}"/>
                    <Image Grid.Column="0" Grid.Row="2" Source="{Binding PrestigeIcon}"/>
                    <Image Grid.Column="0" Grid.Row="4" Source="{Binding TokensIcon}"/>
                    <Image Grid.Column="0" Grid.Row="6" Source="{Binding SoulsIcon}"/>

                    <TextBlock Style="{StaticResource def}" Grid.Column="1" Grid.Row="0" Text="Money:"/>
                    <TextBlock Style="{StaticResource def}" Grid.Column="1" Grid.Row="2" Text="Prestige:"/>
                    <TextBlock Style="{StaticResource def}" Grid.Column="1" Grid.Row="4" Text="Tokens:"/>
                    <TextBlock Style="{StaticResource def}" Grid.Column="1" Grid.Row="6" Text="Souls:"/>

                    <controls:ValidatedTextBox Grid.Column="2" Grid.Row="0" Text="{Binding MoneyText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBox.Validated}" Margin="0,0,8,0"
                                               IsValid="{Binding IsMoneyValid}"/>
                    <controls:ValidatedTextBox Grid.Column="2" Grid.Row="2" Text="{Binding PrestigeText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBox.Validated}" Margin="0,0,8,0"
                                               IsValid="{Binding IsPrestigeValid}"/>
                    <controls:ValidatedTextBox Grid.Column="2" Grid.Row="4" Text="{Binding TokensText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBox.Validated}" Margin="0,0,8,0"
                                               IsValid="{Binding IsTokensValid}"/>
                    <controls:ValidatedTextBox Grid.Column="2" Grid.Row="6" Text="{Binding SoulsText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBox.Validated}" Margin="0,0,8,0"
                                               IsValid="{Binding IsSoulsValid}"/>

                    <controls:CustomButton BackgroundColor="{StaticResource ControlElement.Flat.BackgroundDark}" BackgroundHoverColor="{StaticResource ControlElement.Flat.BackgroundDark.Hover}" Grid.Column="3" Grid.Row="0" Content="Max."
                                           Command="{Binding MaxMoneyCommand}"/>
                    <controls:CustomButton BackgroundColor="{StaticResource ControlElement.Flat.BackgroundDark}" BackgroundHoverColor="{StaticResource ControlElement.Flat.BackgroundDark.Hover}" Grid.Column="3" Grid.Row="2" Content="Max."
                                           Command="{Binding MaxPrestigeCommand}"/>
                    <controls:CustomButton BackgroundColor="{StaticResource ControlElement.Flat.BackgroundDark}" BackgroundHoverColor="{StaticResource ControlElement.Flat.BackgroundDark.Hover}" Grid.Column="3" Grid.Row="4" Content="Max."
                                           Command="{Binding MaxTokensCommand}"/>
                    <controls:CustomButton BackgroundColor="{StaticResource ControlElement.Flat.BackgroundDark}" BackgroundHoverColor="{StaticResource ControlElement.Flat.BackgroundDark.Hover}" Grid.Column="3" Grid.Row="6" Content="Max."
                                           Command="{Binding MaxSoulsCommand}"/>
                </Grid>
            </controls:IconTabItem>
            <controls:IconTabItem Header="Upgrades" Icon="{StaticResource Icon.Upgrades}">
                <TextBlock Style="{StaticResource TextBlock.Base}" HorizontalAlignment="Center" Text="Upgrade editing will be available soon!"/>
            </controls:IconTabItem>
            <controls:IconTabItem Header="Prestige" Icon="{StaticResource Icon.Prestige}">
                <TextBlock Style="{StaticResource TextBlock.Base}" HorizontalAlignment="Center" Text="Prestige editing will be available soon!"/>
            </controls:IconTabItem>
            <controls:IconTabItem Header="Achievements" Icon="{StaticResource Icon.Achievements}">
                <Border BorderBrush="{StaticResource ControlElement.Flat.Border}" BorderThickness="1" CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border CornerRadius="4,4,0,0" BorderThickness="0,0,0,1" BorderBrush="{StaticResource ControlElement.Flat.Border}" Grid.Row="0" Background="{StaticResource ControlElement.Flat.Background}">
                            <StackPanel Orientation="Horizontal" >
                                <TextBlock Style="{StaticResource TextBlock.Base}" Text="Search: " Margin="5,0,0,0"/>
                                <controls:TextBoxPlaceholder Style="{StaticResource TextBox.ListSearch}" PlaceholderText="Search for Achievement..." Width="200"
                                                             Text="{Binding SearchAchievement, UpdateSourceTrigger=PropertyChanged}" MaxLength="50"/>
                                <controls:CustomButton BackgroundColor="{StaticResource ControlElement.Flat.BackgroundDark}" BackgroundHoverColor="{StaticResource ControlElement.Flat.BackgroundDark.Hover2}"
                                                       Content="Unlock All" Width="75" Margin="5,2,0,2"
                                                       Command="{Binding UnlockAllAchievementsCommand}"/>
                                <controls:CustomButton BackgroundColor="{StaticResource ControlElement.Flat.BackgroundDark}" BackgroundHoverColor="{StaticResource ControlElement.Flat.BackgroundDark.Hover2}"
                                                       Content="Claim All" Width="75" Margin="5,2,0,2"
                                                       Command="{Binding ClaimAllAchievementsCommand}"/>
                            </StackPanel>
                        </Border>

                        <ListBox Grid.Row="1" Style="{StaticResource ListBox.Default}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.CanContentScroll="False"
                                 ItemsSource="{Binding AchievementsView}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" HorizontalAlignment="Left" Orientation="Horizontal">
                                            <Image Height="30" Width="30" Source="{Binding Achievement.IconId, Converter={StaticResource IconIdToImageConverter}}"/>
                                            <TextBlock Text="{Binding Achievement.Name}" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <CheckBox Style="{StaticResource CheckBox.Default}" IsChecked="{Binding IsUnlocked, Mode=TwoWay}" Margin="5,0,0,0"/>
                                            <TextBlock Text="Unlocked" VerticalAlignment="Center"/>
                                            <CheckBox Style="{StaticResource CheckBox.Default}" IsChecked="{Binding IsClaimed, Mode=TwoWay}" Margin="15,0,0,0"/>
                                            <TextBlock Text="Claimed" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </controls:IconTabItem>
            <controls:IconTabItem Header="Cosmetics" Icon="{StaticResource Icon.Cosmetics}">
                <TextBlock Style="{StaticResource TextBlock.Base}" HorizontalAlignment="Center" Text="Cosmetics editing will be available soon!"/>
            </controls:IconTabItem>
            <controls:IconTabItem Header="Misc" Icon="{StaticResource Icon.Misc}">
                <TextBlock Style="{StaticResource TextBlock.Base}" HorizontalAlignment="Center" Text="Other editing options will be available soon!"/>
            </controls:IconTabItem>
        </TabControl>
    </Grid>
</UserControl>
