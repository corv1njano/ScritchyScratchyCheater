<Page x:Class="ScritchyScratchyCheater.Views.Pages.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ScritchyScratchyCheater.Views.Pages"
      xmlns:controls="clr-namespace:ScritchyScratchyCheater.Controls"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="500"
      Title="StartPage"
      Background="{StaticResource Window.Background}">

    <Grid Margin="8">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Grid.Row="0" Text="Automatically load the save file from the default location, or browse manually for a save file."
    FontSize="14" Style="{StaticResource TextBlock.Base}" Margin="10" TextWrapping="Wrap" TextAlignment="Center"/>

            <Grid Grid.Row="1" HorizontalAlignment="Center" Margin="0,20,0,0">
                <StackPanel Orientation="Vertical">
                    <controls:IconButton Text="Load Save File" Icon="{StaticResource Icon.File}" Width="200" Click="LoadDefaultSaveFile_Click"/>
                    <TextBlock Text="or" FontSize="14" Style="{StaticResource TextBlock.Base}" Margin="0,8" HorizontalAlignment="Center"/>
                    <controls:IconButton Text="Browse for File" Icon="{StaticResource Icon.Folder}" Width="200" Click="BrowseSaveFile_Click"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <TextBlock VerticalAlignment="Bottom" Text="Made with ♥️ by corv1njano" HorizontalAlignment="Center"
            FontSize="12" Style="{StaticResource TextBlock.Base}" TextWrapping="Wrap" TextAlignment="Center"/>

    </Grid>
</Page>
